# Capsule Backend Environment Variables
# Copy this file to .env and fill in your values

# JWT signing secret — generate a random string (e.g. openssl rand -hex 32)
JWT_SECRET=change-me-to-a-random-secret

# SMTP configuration for OTP emails
# For testing: use Ethereal Email (https://ethereal.email) — auto-configured on first run
# For production: use Gmail with App Password or a transactional email service
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Server port
PORT=3001
