{
  "manifest_version": 3,
  "name": "Capsule",
  "version": "1.1",
  "description": "Capture, merge, and inject AI conversations across ChatGPT, Claude, Gemini, and Perplexity.",
  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "storage",
    "clipboardWrite",
    "contextMenus"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://www.perplexity.ai/*",
    "https://perplexity.ai/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://www.perplexity.ai/*"
      ],
      "js": [
        "content/adapters/chatgpt.js",
        "content/adapters/claude.js",
        "content/adapters/gemini.js",
        "content/adapters/perplexity.js",
        "content/widget.js",
        "content/index.js"
      ]
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
